#!/usr/bin/env bash
# claude-resume-tag — resume a Claude Code session by its tag.
#
#   claude-resume-tag <tag>          # resume most recent session with this exact tag
#   claude-resume-tag                 # interactive picker over all tagged sessions
#   claude-resume-tag --list [query]  # print index (optionally filtered), no resume
#
# Requires: jq. Optional: fzf (used for interactive picker if present).
set -euo pipefail

INDEX="$HOME/.claude/session-tags/index.jsonl"

if ! command -v jq >/dev/null 2>&1; then
  echo "claude-resume-tag: jq is required" >&2
  exit 1
fi

if [ ! -s "$INDEX" ]; then
  echo "No tagged sessions yet ($INDEX is empty)." >&2
  exit 1
fi

if [ "${1:-}" = "--list" ]; then
  shift
  query="${1:-}"
  jq -r --arg q "$query" '
    select($q == "" or ((.tag // "") | ascii_downcase | contains($q | ascii_downcase))
                     or ((.first_msg // "") | ascii_downcase | contains($q | ascii_downcase)))
    | [.ended_at[0:10], (.tag // "-"), (.cwd | split("/") | last), (.first_msg // "")[0:60], .session_id]
    | @tsv
  ' "$INDEX" | column -t -s $'\t'
  exit 0
fi

format_rows() {
  # jq → tsv rows, newest first. Optional filter: case-insensitive substring
  # match on tag OR first_msg. Reads all args as the filter substring.
  local q="${1:-}"
  jq -r --arg q "$q" '
    select(
      $q == "" or
      ((.tag // "")       | ascii_downcase | contains($q | ascii_downcase)) or
      ((.first_msg // "") | ascii_downcase | contains($q | ascii_downcase))
    )
    | [.ended_at[0:10], (.tag // "-"), (.cwd | split("/") | last), (.first_msg // "")[0:60], .session_id]
    | @tsv
  ' "$INDEX" | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--) print a[i]}'
}

if command -v fzf >/dev/null 2>&1; then
  # Pre-filter server-side (case-insensitive substring on tag OR first_msg)
  # so the query is deterministic; fzf then refines within the pre-filtered
  # set. Prevents fzf's loose fuzzy matching from picking unrelated rows.
  # --select-1: auto-pick if exactly one row matches server-side.
  # --exit-0:   don't open picker for zero matches.
  choice=$(
    format_rows "${1:-}" | column -t -s $'\t' \
      | fzf --prompt="resume > " \
            --height=40% --reverse --no-sort --select-1 --exit-0
  ) || { echo "No sessions match '${1:-}'." >&2; exit 1; }
  sid=$(printf '%s' "$choice" | awk '{print $NF}')
else
  # No fzf: substring match, numbered picker if multiple hits.
  # (portable read loop — macOS bash 3.2 has no mapfile)
  rows=()
  while IFS= read -r line; do
    rows+=("$line")
  done < <(format_rows "${1:-}")
  count=${#rows[@]}
  if [ "$count" -eq 0 ]; then
    echo "No sessions match '${1:-}'. Try: claude-resume-tag --list" >&2
    exit 1
  elif [ "$count" -eq 1 ]; then
    sid=$(printf '%s' "${rows[0]}" | awk -F'\t' '{print $NF}')
  else
    echo "(hint: install fzf for an incremental picker — brew install fzf)" >&2
    echo "Multiple matches for '${1:-}' — pick one:" >&2
    i=1
    for r in "${rows[@]}"; do
      IFS=$'\t' read -r rdate rtag rproj rfirst rsid <<<"$r"
      # Fixed-width printf so we don't need BSD `column`
      printf '  %2d. %-10s  %-34s  %-15s  %s\n' \
        "$i" "$rdate" "${rtag:0:34}" "${rproj:0:15}" "$rfirst" >&2
      i=$((i+1))
    done
    printf 'number> ' >&2
    read -r n
    if ! [[ "$n" =~ ^[0-9]+$ ]] || [ "$n" -lt 1 ] || [ "$n" -gt "$count" ]; then
      echo "invalid selection" >&2
      exit 1
    fi
    sid=$(printf '%s' "${rows[n-1]}" | awk -F'\t' '{print $NF}')
  fi
fi

# Claude Code's --resume is directory-scoped: it only finds sessions started
# in the current cwd. Look up the session's original cwd and cd there first.
sess_cwd=$(jq -r --arg sid "$sid" 'select(.session_id == $sid) | .cwd' "$INDEX" | tail -1)
if [ -n "$sess_cwd" ] && [ "$sess_cwd" != "$PWD" ]; then
  if [ -d "$sess_cwd" ]; then
    echo "(cd → $sess_cwd)" >&2
    cd "$sess_cwd"
  else
    echo "warning: session's original cwd '$sess_cwd' no longer exists; trying from $PWD" >&2
  fi
fi

exec claude --resume "$sid"
